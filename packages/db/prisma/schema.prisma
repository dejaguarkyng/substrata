generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DocumentSourceType {
  upload
  seed
  manual
}

enum DocumentOrigin {
  public
  customer_provided
  internal
}

enum DocumentVisibility {
  private
  organization
  public_demo
}

enum ExtractionStatus {
  pending
  completed
  failed
}

enum FactValueType {
  directly_stated
  inferred
  normalized
  calculated
}

enum FactVerificationStatus {
  unreviewed
  verified
  corrected
  rejected
  suppressed
}

enum FactIssueType {
  contradiction
  duplicate
  family_scope_warning
  unverified_identifier
  ambiguous_unit
}

enum ClassificationRunStatus {
  pending
  queued
  running
  completed
  failed
}

enum HumanReviewStatus {
  pending_review
  reviewed
  needs_more_information
  in_review
  approved
  rejected
}

enum ReviewWorkflowState {
  draft_generated
  awaiting_reviewer_assignment
  in_technical_review
  needs_additional_documentation
  escalated
  reviewer_conclusion_recorded
  approved_for_internal_use
  closed
}

enum ReviewPathType {
  product_area
  technical_risk
  encryption_security
  special_environment
  military_space
  general_fallback
}

enum ReviewPathStatus {
  open
  excluded_by_reviewer
  needs_more_evidence
  escalated
  resolved
}

enum RegulationSourceKind {
  primary_regulation
  agency_guidance
  internal_playbook
  reviewer_note
}

enum RegulationVerificationStatus {
  current
  needs_verification
  archived
  superseded
}

enum ECCNCandidateStatus {
  proposed
  approved
  rejected
  modified
  review_required
}

enum ReviewerActionType {
  claim_review
  assign_review
  update_workflow
  verify_fact
  correct_fact
  reject_fact
  suppress_fact
  update_review_path
  update_eccn_candidate
  record_conclusion
  reopen_review
  export_memo
}

enum MembershipRole {
  OWNER
  ADMIN
  REVIEWER
  ANALYST
  VIEWER
}

enum OAuthProvider {
  GOOGLE
}

enum PublicDemoPublicationStatus {
  published
  unpublished
}

model Organization {
  id                 String              @id @default(cuid())
  name               String
  slug               String              @unique
  industry           String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  memberships        Membership[]
  documents          Document[]
  classificationRuns ClassificationRun[]
  extractedSpecs     ExtractedSpec[]
  eccnCandidates     ECCNCandidate[]
  citations          Citation[]
  reviewMemos        ReviewMemo[]
  reviewMemoVersions ReviewMemoVersion[]
  humanReviews       HumanReview[]
  reviewPaths        ReviewPath[]
  regulationSources  RegulationSource[]
  factIssues         FactIssue[]
  reviewerActions    ReviewerAction[]
  auditEvents        AuditEvent[]
  sessions           Session[]
  workspaceInvites   WorkspaceInvite[]
}

model User {
  id                    String                   @id @default(cuid())
  email                 String                   @unique
  name                  String
  emailVerifiedAt       DateTime?
  onboardingCompletedAt DateTime?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  passwordCredential    PasswordCredential?
  oauthIdentities       OAuthIdentity[]
  sessions              Session[]
  memberships           Membership[]
  reviews               HumanReview[]
  auditEvents           AuditEvent[]
  verificationTokens    EmailVerificationToken[]
  passwordResetTokens   PasswordResetToken[]
  sentWorkspaceInvites  WorkspaceInvite[]        @relation("WorkspaceInviteInviter")
  acceptedInvites       WorkspaceInvite[]        @relation("WorkspaceInviteAccepter")
  demoPublications      PublicDemoPublication[]
  reviewerActions       ReviewerAction[]
}

model PasswordCredential {
  id           String   @id @default(cuid())
  userId       String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OAuthIdentity {
  id                String        @id @default(cuid())
  userId            String
  provider          OAuthProvider
  providerAccountId String
  email             String
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id              String        @id @default(cuid())
  userId          String
  organizationId  String
  tokenHash       String        @unique
  csrfTokenHash   String
  expiresAt       DateTime
  lastAccessedAt  DateTime      @default(now())
  revokedAt       DateTime?
  userAgent       String?
  ipAddress       String?
  rotatedFromId   String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([organizationId, expiresAt])
}

model EmailVerificationToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model Membership {
  id               String          @id @default(cuid())
  organizationId   String
  userId           String
  role             MembershipRole  @default(REVIEWER)
  invitedByUserId  String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  organization     Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId, role])
}

model WorkspaceInvite {
  id               String          @id @default(cuid())
  organizationId   String
  email            String
  role             MembershipRole  @default(REVIEWER)
  tokenHash        String          @unique
  invitedByUserId  String
  acceptedByUserId String?
  expiresAt        DateTime
  acceptedAt       DateTime?
  revokedAt        DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  organization     Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedByUser    User            @relation("WorkspaceInviteInviter", fields: [invitedByUserId], references: [id], onDelete: Cascade)
  acceptedByUser   User?           @relation("WorkspaceInviteAccepter", fields: [acceptedByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, email])
  @@index([organizationId, expiresAt])
}

model Document {
  id                 String              @id @default(cuid())
  organizationId     String
  title              String
  fileName           String
  displayFileName    String?
  mimeType           String
  sizeBytes          Int?
  storagePath        String
  sourceType         DocumentSourceType  @default(upload)
  documentType       String?
  manufacturer       String?
  sourceUrl          String?
  sourceDate         DateTime?
  versionLabel       String?
  sha256             String?
  pageCount          Int?
  extractionStatus   ExtractionStatus    @default(pending)
  extractionError    String?
  origin             DocumentOrigin      @default(customer_provided)
  visibility         DocumentVisibility  @default(private)
  accessControl      Json?
  rawText            String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  classificationRuns ClassificationRun[]
  extractedFacts     ExtractedSpec[]

  @@index([organizationId, createdAt])
}

model ClassificationRun {
  id                    String                   @id @default(cuid())
  organizationId        String
  documentId            String
  status                ClassificationRunStatus  @default(pending)
  workflowState         ReviewWorkflowState      @default(draft_generated)
  trigger               String                   @default("manual")
  confidence            Float?
  confidenceRationale   String?
  uncertaintyFlags      String[]
  requiresHumanReview   Boolean                  @default(true)
  reviewerAssignedUserId String?
  reviewerClaimedAt     DateTime?
  finalInternalRecommendation String?
  conclusionDisclaimer  String?
  lastReviewerActionAt  DateTime?
  workerJobId           String?
  workerVersion         String?
  rulesVersion          String?
  extractedTextPath     String?
  structuredOutputPath  String?
  memoArtifactPath      String?
  errorMessage          String?
  completedAt           DateTime?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  organization          Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  document              Document                 @relation(fields: [documentId], references: [id], onDelete: Cascade)
  extractedSpecs        ExtractedSpec[]
  eccnCandidates        ECCNCandidate[]
  reviewPaths           ReviewPath[]
  reviewMemo            ReviewMemo?
  reviewMemoVersions    ReviewMemoVersion[]
  humanReviews          HumanReview[]
  factIssues            FactIssue[]
  reviewerActions       ReviewerAction[]
  citations             Citation[]
  publicDemoPublication PublicDemoPublication?

  @@index([organizationId, createdAt])
  @@index([documentId, createdAt])
}

model PublicDemoPublication {
  id                        String                       @id
  status                    PublicDemoPublicationStatus  @default(unpublished)
  activeClassificationRunId String?                      @unique
  publishedAt               DateTime?
  publishedByUserId         String?
  publicTitle               String?
  publicSummary             String?
  sourceDocumentDisplayName String?
  createdAt                 DateTime                     @default(now())
  updatedAt                 DateTime                     @updatedAt
  activeClassificationRun   ClassificationRun?           @relation(fields: [activeClassificationRunId], references: [id], onDelete: SetNull)
  publishedByUser           User?                        @relation(fields: [publishedByUserId], references: [id], onDelete: SetNull)

  @@index([status, updatedAt])
}

model ExtractedSpec {
  id                  String             @id @default(cuid())
  organizationId      String
  classificationRunId String
  sourceDocumentId    String?
  name                String
  label               String?
  value               String
  unit                String?
  sourceSnippet       String
  sourceText          String?
  sourcePageFrom      Int?
  sourcePageTo        Int?
  boundingBoxes       Json?
  importance          String
  extractionRationale String?
  confidence          Float
  confidenceLevel     String             @default("medium")
  category            String             @default("product_identity")
  valueType           FactValueType      @default(directly_stated)
  extractionMethod    String?
  extractionMethodVersion String?
  extractedAt         DateTime           @default(now())
  reviewerStatus      FactVerificationStatus @default(unreviewed)
  reviewerNote        String?
  reviewerCorrectedValue String?
  reviewerCorrectedUnit  String?
  suppressFromMemo    Boolean            @default(false)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  organization        Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  classificationRun   ClassificationRun  @relation(fields: [classificationRunId], references: [id], onDelete: Cascade)
  sourceDocument      Document?          @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  reviewPathFacts     ReviewPathFact[]
  candidateFactMappings CandidateFactMapping[]
  factIssuesPrimary   FactIssue[]        @relation("FactIssuePrimaryFact")
  factIssuesRelated   FactIssue[]        @relation("FactIssueRelatedFact")

  @@index([organizationId, createdAt])
  @@index([classificationRunId])
}

model ECCNCandidate {
  id                    String             @id @default(cuid())
  organizationId        String
  classificationRunId   String
  eccn                  String
  title                 String
  rationale             String
  confidence            Float
  confidenceLevel       String             @default("medium")
  confidenceRationale   String?
  status                ECCNCandidateStatus @default(review_required)
  officialTitle         String?
  regulationSourceId    String?
  regulationVersion     String?
  paragraphReference    String?
  controlCriteria       Json?
  mayApplyReasons       String[]
  mayNotApplyReasons    String[]
  matchedTechnicalFacts String[]
  whyItMayApply         String
  whyItMayNotApply      String
  missingInformation    String[]
  reviewerQuestions     String[]
  uncertaintyFlags      String[]
  alternativeCandidates Json?
  reviewerDisposition   String?
  reviewerDispositionRationale String?
  reviewPathId          String?
  isSpecificEccn        Boolean            @default(true)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  organization          Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  classificationRun     ClassificationRun  @relation(fields: [classificationRunId], references: [id], onDelete: Cascade)
  citations             Citation[]
  regulationSource      RegulationSource?  @relation(fields: [regulationSourceId], references: [id], onDelete: SetNull)
  reviewPath            ReviewPath?        @relation(fields: [reviewPathId], references: [id], onDelete: SetNull)
  factMappings          CandidateFactMapping[]

  @@index([organizationId, createdAt])
  @@index([classificationRunId])
}

model Citation {
  id                  String             @id @default(cuid())
  organizationId      String
  classificationRunId String
  eccnCandidateId     String?
  reviewPathId        String?
  regulationSourceId  String?
  sourceTitle         String
  sourceUrl           String?
  sourceSection       String?
  quotedText          String
  relevanceNote       String
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  organization        Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  classificationRun   ClassificationRun  @relation(fields: [classificationRunId], references: [id], onDelete: Cascade)
  eccnCandidate       ECCNCandidate?     @relation(fields: [eccnCandidateId], references: [id], onDelete: SetNull)
  reviewPath          ReviewPath?        @relation(fields: [reviewPathId], references: [id], onDelete: SetNull)
  regulationSource    RegulationSource?  @relation(fields: [regulationSourceId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([classificationRunId])
}

model ReviewMemo {
  id                  String             @id @default(cuid())
  organizationId      String
  classificationRunId String             @unique
  contentMarkdown     String
  versionNumber       Int                @default(1)
  reviewStateSnapshot ReviewWorkflowState @default(draft_generated)
  reviewerStatusSnapshot String?
  disclaimer          String?
  generatedBy         String             @default("worker_stub")
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  organization        Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  classificationRun   ClassificationRun  @relation(fields: [classificationRunId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
}

model ReviewMemoVersion {
  id                  String             @id @default(cuid())
  organizationId      String
  classificationRunId String
  versionNumber       Int
  contentMarkdown     String
  reviewStateSnapshot ReviewWorkflowState
  reviewerStatusSnapshot String?
  disclaimer          String?
  generatedBy         String
  createdAt           DateTime           @default(now())
  organization        Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  classificationRun   ClassificationRun  @relation(fields: [classificationRunId], references: [id], onDelete: Cascade)

  @@unique([classificationRunId, versionNumber])
  @@index([organizationId, createdAt])
}

model HumanReview {
  id                  String             @id @default(cuid())
  organizationId      String
  classificationRunId String
  reviewerId          String
  status              HumanReviewStatus  @default(pending_review)
  workflowState       ReviewWorkflowState @default(awaiting_reviewer_assignment)
  approvalScope       String?
  finalInternalRecommendation String?
  caveats             String?
  assumptions         String?
  missingInformation  String?
  conclusionRecordedAt DateTime?
  claimedAt           DateTime?
  reopenedAt          DateTime?
  notes               String?
  reviewedAt          DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  organization        Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  classificationRun   ClassificationRun  @relation(fields: [classificationRunId], references: [id], onDelete: Cascade)
  reviewer            User               @relation(fields: [reviewerId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([classificationRunId, createdAt])
}

model ReviewPath {
  id                  String             @id @default(cuid())
  organizationId      String
  classificationRunId String
  type                ReviewPathType
  status              ReviewPathStatus   @default(open)
  title               String
  scope               String
  whyTriggered        String
  technicalRiskArea   String?
  missingInformation  String[]
  reviewerQuestions   String[]
  reviewerNotes       String?
  decisionRationale   String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  organization        Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  classificationRun   ClassificationRun  @relation(fields: [classificationRunId], references: [id], onDelete: Cascade)
  facts               ReviewPathFact[]
  citations           Citation[]
  eccnCandidates      ECCNCandidate[]

  @@index([organizationId, createdAt])
  @@index([classificationRunId, status])
}

model ReviewPathFact {
  id            String        @id @default(cuid())
  reviewPathId  String
  extractedSpecId String
  createdAt     DateTime      @default(now())
  reviewPath    ReviewPath     @relation(fields: [reviewPathId], references: [id], onDelete: Cascade)
  extractedSpec ExtractedSpec  @relation(fields: [extractedSpecId], references: [id], onDelete: Cascade)

  @@unique([reviewPathId, extractedSpecId])
}

model RegulationSource {
  id                  String                       @id @default(cuid())
  organizationId      String
  authority           String
  regulationTitle     String
  regulationVersion   String?
  citationText        String
  citationUrl         String?
  sourceIdentifier    String?
  section             String?
  paragraph           String?
  kind                RegulationSourceKind
  lastVerifiedAt      DateTime?
  verificationStatus  RegulationVerificationStatus @default(needs_verification)
  createdAt           DateTime                     @default(now())
  updatedAt           DateTime                     @updatedAt
  organization        Organization                 @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  citations           Citation[]
  eccnCandidates      ECCNCandidate[]

  @@index([organizationId, createdAt])
}

model CandidateFactMapping {
  id               String         @id @default(cuid())
  eccnCandidateId  String
  extractedSpecId  String
  criterionLabel   String
  matchedValue     String
  comparisonResult String
  notes            String?
  createdAt        DateTime       @default(now())
  eccnCandidate    ECCNCandidate  @relation(fields: [eccnCandidateId], references: [id], onDelete: Cascade)
  extractedSpec    ExtractedSpec  @relation(fields: [extractedSpecId], references: [id], onDelete: Cascade)

  @@unique([eccnCandidateId, extractedSpecId, criterionLabel])
}

model FactIssue {
  id                  String        @id @default(cuid())
  organizationId      String
  classificationRunId String
  primaryFactId       String?
  relatedFactId       String?
  issueType           FactIssueType
  summary             String
  details             String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  organization        Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  classificationRun   ClassificationRun @relation(fields: [classificationRunId], references: [id], onDelete: Cascade)
  primaryFact         ExtractedSpec? @relation("FactIssuePrimaryFact", fields: [primaryFactId], references: [id], onDelete: SetNull)
  relatedFact         ExtractedSpec? @relation("FactIssueRelatedFact", fields: [relatedFactId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([classificationRunId, issueType])
}

model ReviewerAction {
  id                  String             @id @default(cuid())
  organizationId      String
  classificationRunId String
  actorUserId         String
  actionType          ReviewerActionType
  targetType          String
  targetId            String
  details             Json?
  createdAt           DateTime           @default(now())
  organization        Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  classificationRun   ClassificationRun  @relation(fields: [classificationRunId], references: [id], onDelete: Cascade)
  actorUser           User               @relation(fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([classificationRunId, createdAt])
}

model AuditEvent {
  id             String        @id @default(cuid())
  organizationId String
  actorUserId    String?
  actor          String
  action         String
  entityType     String
  entityId       String
  metadata       Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User?         @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([entityType, entityId])
}
