POSTGRES_DB=substrata
POSTGRES_USER=substrata
POSTGRES_PASSWORD=change-this-postgres-password
DATABASE_URL=postgresql://substrata:change-this-postgres-password@postgres:5432/substrata?schema=public

APP_URL=https://substrata.example.com
WEB_APP_URL=https://substrata.example.com
API_URL=https://substrata.example.com/api
API_PORT=4100
WEB_PORT=3100
NEXT_PUBLIC_API_BASE_URL=/api
API_CORS_ORIGIN=https://substrata.example.com

STORAGE_DRIVER=local
LOCAL_STORAGE_ROOT=./tmp/storage

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://substrata.example.com/api/v1/auth/google/callback

SESSION_SECRET=replace-with-a-long-random-secret
SESSION_COOKIE_NAME=substrata_session
SESSION_COOKIE_DOMAIN=
PUBLIC_DEMO_ADMIN_EMAILS=

EMAIL_PROVIDER=zeptomail
ZEPTOMAIL_SEND_MAIL_TOKEN=
EMAIL_FROM_ADDRESS=
EMAIL_FROM_NAME=Substrata
EMAIL_REPLY_TO=

AI_ENABLED=true
AI_PROVIDER=gemini
GEMINI_API_KEY=
AI_MODEL=gemini-2.5-flash
AI_MAX_INPUT_CHARS=120000
AI_DEMO_PUBLIC_DOCS_ONLY=true
